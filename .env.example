# OASIS SYSTEM CORE -- environment template.
# Copy to .env and fill in real values. Never commit the real .env file.
#
# Previously this file didn't exist at all, even though every service in
# docker-compose.yml declares `env_file: .env` -- there was no template
# anywhere showing a new contributor what variables they needed to set.

# --- Database (app-tier) ---
DB_USER=oasis_admin
DB_PASS=changeme_use_a_real_strong_password
DB_NAME=oasis_db
DB_HOST=postgres
DB_PORT=5432
# Leave unset for local docker-compose (TCP to the `postgres` service above).
# Set only when running on Cloud Run with a Cloud SQL Unix socket:
# INSTANCE_CONNECTION_NAME=project-f537c014-8ae2-4195-9f3:europe-west1:oasis-db-primary

# Local dev / tests only -- uses sqlite:///oasis_local.db instead of Postgres.
USE_SQLITE=false

# --- Redis (Sync Layer) ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# --- Qdrant (Memory Fabric) ---
QDRANT_URL=http://qdrant:6333
QDRANT_KEY=

# --- app-tier security (see app-tier/src/security.py) ---
# Leave unset for local dev (auth becomes a no-op with a startup warning).
# Set in production via Secret Manager -- see infra/deploy.sh step 3.
APP_API_KEY=
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://oasis-system-core.com,https://www.oasis-system-core.com
ENVIRONMENT=development

# --- Memory Fabric ingestion (infra/ingest.py) ---
OPENAI_API_KEY=sk-...

# --- crypto-bot (Solana trading bot, see crypto-bot/bot.py) ---
# DRY RUN by default -- no real transaction is ever submitted unless you
# explicitly set this to false AND wire a signer in execute_swap().
OASIS_BOT_DRY_RUN=true
SOLANA_RPC_URL=https://api.devnet.solana.com
JUPITER_QUOTE_URL=https://quote-api.jup.ag/v6/quote
# Required since the 2026-06-30 end of the free-tier grandfathering on the
# old Jupiter portal -- get one from https://portal.jup.ag
JUPITER_API_KEY=
OASIS_BOT_POLL_INTERVAL_S=15
OASIS_BOT_QUOTE_AMOUNT_LAMPORTS=1000000000
OASIS_BOT_MOMENTUM_BUY_PCT=0.5
OASIS_BOT_MAX_POSITION_SOL=1.0
